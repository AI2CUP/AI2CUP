# ──────────────────────────────────────────────────
# AI2CUP Backend Environment Variables
# ──────────────────────────────────────────────────
# Copy this file to .env and adjust values as needed
# All variables are prefixed with AI2CUP_

# App
AI2CUP_DEBUG=true
AI2CUP_APP_VERSION=2.0.0-dev

# CORS (JSON array of allowed origins)
AI2CUP_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173"]

# ML
AI2CUP_AUTO_TRAIN_ON_STARTUP=true
AI2CUP_MODEL_DIR=app/data/storage
AI2CUP_PRICE_MODEL_FILENAME=trained_model.joblib

# Data
AI2CUP_DATASET_PATH=app/data/storage/coffee_prices.csv

# Currency
AI2CUP_USD_TO_ETB=57.0

# ── Future ──
# AI2CUP_DATABASE_URL=postgresql://user:password@localhost:5432/ai2cup
# AI2CUP_JWT_SECRET=your-secret-key-change-in-production
# AI2CUP_JWT_ALGORITHM=HS256
# AI2CUP_JWT_EXPIRY_MINUTES=60
