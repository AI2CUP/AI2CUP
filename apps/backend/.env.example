# ── App ──
AI2CUP_DEBUG=true
AI2CUP_APP_VERSION=2.0.0-dev
AI2CUP_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173"]

# ── ML ──
AI2CUP_AUTO_TRAIN_ON_STARTUP=true
AI2CUP_MODEL_DIR=ckpt
AI2CUP_PRICE_MODEL_FILENAME=trained_model_v2.joblib

# ── Database (set your connection string here) ──
# AI2CUP_DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── Auth ──
# AI2CUP_JWT_SECRET=change-me-to-a-random-uuid
# AI2CUP_JWT_ALGORITHM=HS256
# AI2CUP_JWT_EXPIRY_MINUTES=60

# ── Currency ──
AI2CUP_USD_TO_ETB=57.0
